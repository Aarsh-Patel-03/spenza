rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isGroupMember(groupId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId)
        && request.resource.data.mobile is string
        && request.resource.data.isMobileVerified == true;
      allow update: if isSelf(userId)
        && request.resource.data.mobile == resource.data.mobile
        && request.resource.data.isMobileVerified == true;
    }

    match /groups/{groupId} {
      allow read: if isGroupMember(groupId);
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.createdBy
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if isGroupMember(groupId);
      allow delete: if false;

      match /expenses/{expenseId} {
        allow read, create, update: if isGroupMember(groupId);
        allow delete: if isGroupMember(groupId);
      }

      match /settlements/{settlementId} {
        allow read, create, update: if isGroupMember(groupId);
        allow delete: if false;
      }
    }
  }
}
